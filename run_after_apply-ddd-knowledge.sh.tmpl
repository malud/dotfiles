{{ if lookPath "gh" -}}
#!/usr/bin/env bash
set -euo pipefail

if ! gh auth status &>/dev/null; then
    echo "Skipping DDD knowledge base: gh not authenticated"
    exit 0
fi

REPO="malud/domain-driven-design"
DEST="$HOME"

if ! gh api "repos/$REPO" --jq '.id' &>/dev/null; then
    echo "Skipping DDD knowledge base: no access to $REPO"
    exit 0
fi

fetch_file() {
    gh api "repos/$REPO/contents/$1" --jq '.content' | base64 -d
}

fetch_dir_list() {
    gh api "repos/$REPO/contents/$1" --jq '.[].path'
}

fetch_dir_recursive() {
    local remote_dir="$1" local_dir="$2"
    mkdir -p "$local_dir"
    gh api "repos/$REPO/contents/$remote_dir" --jq '.[] | .path + "\t" + .type' | while IFS=$'\t' read -r path type; do
        if [[ "$type" == "dir" ]]; then
            fetch_dir_recursive "$path" "$local_dir/$(basename "$path")"
        else
            fetch_file "$path" > "$local_dir/$(basename "$path")"
        fi
    done
}

# 1. Merge settings.json
mkdir -p "$DEST/.claude"
DDD_SETTINGS=$(fetch_file ".claude/settings.json")
if [[ -f "$DEST/.claude/settings.json" ]]; then
    jq -s '.[0] as $existing | .[1] as $ddd |
        ($existing * {
            permissions: {
                allow: ([$existing.permissions.allow, $ddd.permissions.allow] | add | unique),
                deny: ($existing.permissions.deny // [])
            }
        })' "$DEST/.claude/settings.json" <(echo "$DDD_SETTINGS") > "$DEST/.claude/settings.json.tmp"
    mv "$DEST/.claude/settings.json.tmp" "$DEST/.claude/settings.json"
else
    echo "$DDD_SETTINGS" > "$DEST/.claude/settings.json"
fi

# 2. Copy agents/
rm -rf "$DEST/.claude/agents"
mkdir -p "$DEST/.claude/agents"
for file in $(fetch_dir_list ".claude/agents"); do
    fetch_file "$file" > "$DEST/.claude/agents/$(basename "$file")"
done

# 3. Copy skills/
rm -rf "$DEST/.claude/skills"
fetch_dir_recursive ".claude/skills" "$DEST/.claude/skills"

# 4. Copy languages/ and references/
for dir in languages references; do
    rm -rf "$DEST/$dir"
    mkdir -p "$DEST/$dir"
    for file in $(fetch_dir_list "$dir"); do
        fetch_file "$file" > "$DEST/$dir/$(basename "$file")"
    done
done

# 5. Create CLAUDE.md (DevPod info + DDD content)
DDD_CLAUDE=$(fetch_file "CLAUDE.md")
cat > "$DEST/CLAUDE.md" << 'HEADER'
# CLAUDE.md

## DevPod

Execute commands inside devcontainers:

```bash
devpod ssh <project_dir> --command "cd /workspace && <command>"
```

The workspace is mounted at `/workspace`.

## Obsidian CLI

Obsidian includes a CLI for vault management. Binary is at `/Applications/Obsidian.app/Contents/MacOS/obsidian` (added to PATH via `~/.bashrc`).

- Run `obsidian help` to see all available commands
- Run `obsidian help <command>` for detailed usage of a specific command
- Docs: https://help.obsidian.md/cli

---

HEADER
echo "$DDD_CLAUDE" >> "$DEST/CLAUDE.md"

echo "DDD knowledge base applied"
{{ end -}}
