{{- /* chezmoi:modify-template */ -}}
{{- $defaults := dict
      "permissions" (dict
        "allow" (list
          "Bash(ls:*)" "Bash(cat:*)" "Bash(less:*)" "Bash(head:*)"
          "Bash(tail:*)" "Bash(find:*)" "Bash(tree:*)" "Bash(file:*)"
          "Bash(wc:*)" "Bash(stat:*)" "Bash(which:*)"
          "Bash(git status:*)" "Bash(git log:*)" "Bash(git diff:*)"
          "Bash(git branch:*)" "Bash(git show:*)" "Bash(git -C:*)"
          "Bash(gh run list*)" "Bash(gh run view*)"
          "Bash(gh issue list*)" "Bash(gh issue view*)"
          "Bash(gh pr list*)" "Bash(gh pr view*)"
          "Bash(gh api repos/*/issues/*)" "Bash(gh api repos/*/pulls/*)"
        )
        "deny" (list
          "Read(**/.env)" "Read(**/*.ovpn)" "Read(**/*.OVPN)"
          "Read(~/.ssh/*)" "Read(~/.kube/*)" "Read(~/.docker/*)" "Read(~/.npmrc)"
        )
      )
      "enabledPlugins" (dict
        "context7@claude-plugins-official" true
        "frontend-design@claude-plugins-official" true
        "interface-design@interface-design" true
      )
-}}
{{- /* Existing file wins for shared keys, defaults fill in missing keys */ -}}
{{- if .chezmoi.stdin -}}
{{-   $defaults = merge $defaults (fromJson .chezmoi.stdin) -}}
{{- end -}}
{{- /* Hooks and statusLine — always enforced from dotfiles */ -}}
{{- $defaults = setValueAtPath "hooks" (dict
      "PreToolUse" (list
        (dict
          "matcher" "Bash"
          "hooks" (list
            (dict
              "type" "command"
              "command" (printf "bash %s/.claude/hooks/gitui-before-commit.sh" .chezmoi.homeDir)
            )
          )
        )
      )
    ) $defaults
-}}
{{- $defaults = setValueAtPath "statusLine" (dict
      "type" "command"
      "command" (printf "bash %s/.claude/statusline-command.sh" .chezmoi.homeDir)
    ) $defaults
-}}
{{- toPrettyJson $defaults }}
